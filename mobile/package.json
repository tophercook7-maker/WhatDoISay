{
  "name": "what-do-i-say-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "check:replies": "rm -rf .reply-check && tsc scripts/checkReplyQuality.ts services/replyService.ts types/index.ts --outDir .reply-check --module commonjs --target ES2020 --skipLibCheck --esModuleInterop && node .reply-check/scripts/checkReplyQuality.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
